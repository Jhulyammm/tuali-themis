# Dependencias y build outputs — se generan en el Docker build
node_modules/
**/node_modules/
.next/
**/.next/
dist/
**/dist/
build/
**/build/
out/
**/out/

# Caches
.cache/
.pnpm-store/
**/*.tsbuildinfo

# Env files — NUNCA al build context (se montan via env_file en compose)
.env
.env.local
.env.production
.env.development
.env.*.local
apps/*/.env.local

# Git + repo metadata
.git/
.gitignore
.gitattributes

# Editor / OS
.vscode/
.idea/
.DS_Store
Thumbs.db

# Logs
*.log
npm-debug.log*
pnpm-debug.log*

# Documentation que no necesitamos en el image
*.md
docs/
plans/
*.png
*.jpg
*.jpeg
*.gif
*.svg
!apps/operator-ui/public/**/*.svg
!apps/operator-ui/public/**/*.png

# Test artifacts
coverage/
.nyc_output/
*.test.ts
*.spec.ts

# Data del filesystem fallback — al deploy le pasamos MongoDB
data/playbooks-store.json
data/executions-store.json
