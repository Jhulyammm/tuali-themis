# ============================================================
# Capa 1: Anthropic (Claude Agent + Computer Use)
# Get keys at https://console.anthropic.com
# ============================================================
ANTHROPIC_API_KEY=

# ============================================================
# Capa 1: Azure OpenAI for Students (organizadores entregan)
# Backup LLM si Anthropic se queda sin créditos
# ============================================================
AZURE_OPENAI_API_KEY=
AZURE_OPENAI_ENDPOINT=

# ============================================================
# Capa 1: Browserbase (Stagehand headless browser)
# Get keys at https://browserbase.com
# ============================================================
BROWSERBASE_API_KEY=
BROWSERBASE_PROJECT_ID=

# ============================================================
# Capa 2: ElevenLabs (voz mexicana de Themis) [MLH PRIZE]
# Get keys at https://elevenlabs.io
# ============================================================
ELEVENLABS_API_KEY=
ELEVENLABS_VOICE_ID=

# Whisper for narración del operador durante observación
OPENAI_API_KEY=

# ============================================================
# Capa 3: Google Gemini (razonamiento contextual) [MLH PRIZE]
# Get keys at https://aistudio.google.com
# ============================================================
GOOGLE_API_KEY=

# ============================================================
# Capa 4: MongoDB Atlas (knowledge graph) [MLH PRIZE]
# Free M0 cluster: https://cloud.mongodb.com
# ============================================================
MONGODB_URI=

# ============================================================
# Supabase (datos relacionales: playbooks, executions, tiendas)
# Get from https://supabase.com -> Project Settings -> API
# ============================================================
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
DATABASE_URL=

# ============================================================
# Capa 5: Vultr (deploy en producción) [MLH PRIZE]
# Get keys at https://my.vultr.com/settings/#settingsapi
# ============================================================
VULTR_API_KEY=

# ============================================================
# Capa 6: Solana devnet (on-chain provenance) [MLH PRIZE]
# Generate wallet con Phantom o `solana-keygen new`
# Faucet: https://faucet.solana.com (devnet, gratis)
# ============================================================
SOLANA_RPC_URL=https://api.devnet.solana.com
SOLANA_WALLET_SECRET_KEY=

# ============================================================
# Local URLs
# ============================================================
NEXT_PUBLIC_OPERATOR_URL=http://localhost:3000
NEXT_PUBLIC_ERP_DESTINO_URL=http://localhost:3001

# Sistema A (origen público) — no requiere key, solo URL
NEXT_PUBLIC_SOURCE_SYSTEM_URL=https://automationexercise.com
