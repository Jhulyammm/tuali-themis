{
  "name": "themis",
  "version": "0.0.1",
  "private": true,
  "description": "Themis - Agente Cognitivo Verificable. Aprende procesos web por observación, razona con contexto, recuerda y prueba en blockchain. Hack4Her 2026.",
  "scripts": {
    "dev:operator": "pnpm --filter operator-ui dev",
    "dev:destino": "pnpm --filter erp-destino dev",
    "env:sync": "node -e \"require('fs').copyFileSync('.env.local', 'apps/operator-ui/.env.local'); console.log('✓ .env.local copiado a operator-ui')\"",
    "build": "pnpm -r build",
    "lint": "pnpm -r lint",
    "typecheck": "pnpm -r typecheck",
    "setup:solana": "tsx scripts/setup-solana-wallet.ts"
  },
  "devDependencies": {
    "@solana/web3.js": "^1.95.0",
    "@types/node": "^22.0.0",
    "bs58": "^6.0.0",
    "tsx": "^4.19.0",
    "typescript": "^5.6.0"
  },
  "packageManager": "pnpm@9.12.0",
  "engines": {
    "node": ">=20"
  }
}
