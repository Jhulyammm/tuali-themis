# Hoist TODAS las deps al node_modules raíz (como npm/yarn).
# Necesario para que Vercel encuentre transitive deps (Stagehand, MongoDB, etc.)
# en monorepo pnpm sin hacer trace surgery.
shamefully-hoist=true

# Permite que workspace deps usen "workspace:*" sin frozen-lockfile
prefer-workspace-packages=true

# Auto-instalar peer deps
auto-install-peers=true
